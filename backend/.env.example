# LLM Provider: "openai" or "bedrock"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# AWS Bedrock (Claude)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# App
DATABASE_URL=sqlite:///./sys_knowledge_hub.db
UPLOAD_DIR=../uploads
CHROMA_DIR=./chroma_db
SECRET_KEY=change-me-in-production

# AIST Credentials
AIST_USER=YOUR_AIST_USER
AIST_PASSWORD=YOUR_AIST_PSW
